rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function hasRecentGpsVerification(uid) {
      let user = get(/databases/$(database)/documents/users/$(uid));
      return user.exists() &&
        user.data.gpsVerifiedAt is timestamp &&
        user.data.gpsVerifiedAt > request.time - duration.value(2, 'h');
    }

    function isApplyingToJob() {
      return request.resource.data.applicantIds is list &&
        resource.data.applicantIds is list &&
        !(request.auth.uid in resource.data.applicantIds) &&
        (request.auth.uid in request.resource.data.applicantIds);
    }

    function conversationNow(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function conversationAfter(conversationId) {
      return getAfter(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function isConversationParticipantRead(conversationId) {
      let conv = conversationNow(conversationId);
      return conv.exists() &&
        conv.data.participants is list &&
        request.auth.uid in conv.data.participants;
    }

    function isConversationParticipantWrite(conversationId) {
      let conv = conversationAfter(conversationId);
      return conv.exists() &&
        conv.data.participants is list &&
        request.auth.uid in conv.data.participants;
    }

    function isConversationLockedNow(conversationId) {
      let conv = conversationNow(conversationId);
      let locked = ('lockedBy' in conv.data) ? conv.data.lockedBy : {};
      return locked is map &&
        request.auth.uid in locked &&
        locked[request.auth.uid] == true;
    }

    function isRestrictedConversation(conversationId) {
      let conv = conversationAfter(conversationId);
      let scope = ('scopeKey' in conv.data) ? conv.data.scopeKey : '';
      let label = ('contextLabel' in conv.data) ? conv.data.contextLabel : '';
      let scopeRestricted = scope is string &&
        (scope.matches('^job:.*') || scope.matches('^service:.*'));
      let labelRestricted = label is string &&
        (label.matches('^Job:.*') || label.matches('^Service:.*'));
      return scopeRestricted || labelRestricted;
    }

    function isConversationLockedForWriter(conversationId) {
      let conv = conversationAfter(conversationId);
      let locked = ('lockedBy' in conv.data) ? conv.data.lockedBy : {};
      return locked is map &&
        request.auth.uid in locked &&
        locked[request.auth.uid] == true;
    }

    function gpsFieldUnchangedForUserWrite() {
      let hadField = resource != null && ('gpsVerifiedAt' in resource.data);
      let hasField = 'gpsVerifiedAt' in request.resource.data;
      return !hasField ||
        (hadField && request.resource.data.gpsVerifiedAt == resource.data.gpsVerifiedAt) ||
        (!hadField && request.resource.data.gpsVerifiedAt == null);
    }

    // User profile docs
    match /users/{userId} {
      allow read: if isMe(userId);
      // Users can edit their own profile, but cannot spoof gpsVerifiedAt from client.
      allow create, update: if isMe(userId) && gpsFieldUnchangedForUserWrite();
      allow delete: if isMe(userId);
    }

    // Jobs / Services / Reviews / Reports / Huddle collections.
    // Keep writes auth-gated to match current app behavior.
    match /jobs/{jobId} {
      allow read: if true;
      allow create, delete: if signedIn();
      allow update: if signedIn() &&
        (!isApplyingToJob() || hasRecentGpsVerification(request.auth.uid));
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /reports/{reportId} {
      allow read, write: if signedIn();
    }

    // The Huddle feed and replies
    match /huddle_posts/{postId} {
      allow read, write: if signedIn();

      match /replies/{replyId} {
        allow read, write: if signedIn();
      }
    }

    // Conversations are private between participants only.
    match /conversations/{conversationId} {
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participants;
      allow read: if signedIn() &&
        request.auth.uid in resource.data.participants;
      allow update: if signedIn() &&
        request.auth.uid in resource.data.participants &&
        !isConversationLockedNow(conversationId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn() && isConversationParticipantRead(conversationId);
        allow create, update, delete: if signedIn() &&
          isConversationParticipantWrite(conversationId) &&
          !isConversationLockedForWriter(conversationId) &&
          (!isRestrictedConversation(conversationId) ||
            hasRecentGpsVerification(request.auth.uid));
      }
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
