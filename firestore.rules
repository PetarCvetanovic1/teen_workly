rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // User profile docs
    match /users/{userId} {
      allow read, write: if isMe(userId);
    }

    // Jobs / Services / Reviews / Reports / Huddle collections.
    // Keep writes auth-gated to match current app behavior.
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /reports/{reportId} {
      allow read, write: if signedIn();
    }

    // The Huddle feed and replies
    match /huddle_posts/{postId} {
      allow read, write: if signedIn();

      match /replies/{replyId} {
        allow read, write: if signedIn();
      }
    }

    // Conversations are private between participants only.
    match /conversations/{conversationId} {
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participants;
      allow read, update, delete: if signedIn() &&
        request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        // Keep chat unblocked while conversation docs are lazily created.
        allow read, write: if signedIn();
      }
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
